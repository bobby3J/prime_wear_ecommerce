TELECEL_CASH_WEBHOOK_SECRET=

# Bank/Card gateway
BANK_INIT_URL=
BANK_API_TOKEN=
BANK_WEBHOOK_SECRET=

# Business destination details shown on payment page
BUSINESS_MTN_MOMO_NUMBER=
